<?xml version="1.0" encoding="UTF-8"?>
<CycloneDDS xmlns="https://cdds.io/config">
  <Domain id="any">
    <General>
      <Interfaces>
        <!-- Bind to the WiFi interface shared between Pi and PC.
             Replace 'wlp0s20f3' with your actual interface name on each machine.
             Run 'ip -o link show' or 'ip -o addr show' to find it.
             On systems with unpredictable interface names, use bind="<ip_address>" instead. -->
        <NetworkInterface name="wlp0s20f3" />
      </Interfaces>
      <AllowMulticast>true</AllowMulticast>
    </General>
    <Discovery>
      <ParticipantIndex>auto</ParticipantIndex>
      <MaxAutoParticipantIndex>32</MaxAutoParticipantIndex>
    </Discovery>
  </Domain>
</CycloneDDS>
